*.log
logs/

# ── Node ──────────────────────────────────────────────────
node_modules/
package-lock.json
dashboard/package-lock.json

# ── Frontend build output (regenerated by npm run build) ──
dashboard/dist/

# ── ML models (large binary files — regenerated by pipeline) ──
results/cv/model/*.keras
results/cv/model/*.pkl

# ── Generated results (plots, reports, runtime files) ─────
results/**/*.png
results/**/*.json
results/**/*.db
# Ignore most CSVs (large / regenerated) but keep the 4 the API needs
results/**/*.csv
!results/feature_matrix.csv
!results/if/anomaly_scores.csv
!results/rul/rul_predictions.csv
!results/rul/rul_metrics.csv

# ── NumPy image arrays (regenerated by signal_to_image.py) ─
data/images/

# ── Stale duplicate results under src/ ────────────────────
src/results/

# ── Model backups ─────────────────────────────────────────
results/if/models_backup_*/

