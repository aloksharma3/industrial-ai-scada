*.ipynb_checkpoints

# ── ML models (large binary files — regenerated by pipeline) ──
results/if/models/*.pkl
results/rul/models/*.pt
results/rca/cmms.db

# ── Data (too large for git) ──────────────────────────────
data/raw/
data/*.db
*.h5
*.hdf5

# ── NASA IMS dataset (download separately) ────────────────
data/IMS/
data/nasa/
*.7z
*.rar

